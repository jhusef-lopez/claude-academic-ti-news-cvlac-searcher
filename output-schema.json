{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "doctoral-ti-news-cvlac-output",
  "title": "Doctoral TI News CvLAC — salida enriquecida Colombia",
  "description": "Esquema de salida para la skill 04-doctoral-ti-news-cvlac. Usar null cuando un dato no esté verificado.",
  "type": "object",
  "required": [
    "meta",
    "resumen_ejecutivo",
    "hallazgos",
    "preguntas_doctorales_sugeridas",
    "riesgos_metodologicos",
    "vacios_investigacion"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "tema",
        "ventana_temporal",
        "fecha_generacion",
        "formato_solicitado",
        "total_hallazgos",
        "fuentes_utilizadas",
        "enfoque_colombiano",
        "cvlac_consultado"
      ],
      "properties": {
        "tema": { "type": "string" },
        "ventana_temporal": { "type": "string" },
        "profundidad": {
          "type": "string",
          "enum": ["breve", "media", "profunda"]
        },
        "region": { "type": "string", "default": "Colombia" },
        "enriquecer_cvlac": {
          "type": "string",
          "enum": ["si", "no", "solo_colombianos"]
        },
        "idioma_salida": { "type": "string", "default": "es" },
        "fecha_generacion": {
          "type": "string",
          "description": "ISO 8601, ej. 2026-06-29T14:30:00Z"
        },
        "formato_solicitado": {
          "type": "string",
          "enum": ["json", "texto", "ambos"]
        },
        "total_hallazgos": { "type": "integer", "minimum": 0 },
        "enfoque_colombiano": { "type": "boolean" },
        "cvlac_consultado": { "type": "boolean" },
        "fuentes_utilizadas": {
          "type": "array",
          "items": { "type": "string" },
          "description": "APIs y sitios consultados con URL base"
        }
      }
    },
    "resumen_ejecutivo": {
      "type": "string",
      "description": "5-8 líneas incluyendo contexto Colombia/LATAM cuando aplique"
    },
    "hallazgos": {
      "type": "array",
      "items": { "$ref": "#/definitions/hallazgo" }
    },
    "preguntas_doctorales_sugeridas": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "riesgos_metodologicos": {
      "type": "array",
      "items": { "type": "string" }
    },
    "vacios_investigacion": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "definitions": {
    "cvlac": {
      "type": "object",
      "required": [
        "perfil_encontrado",
        "url",
        "cod_rh",
        "categoria",
        "afiliacion_principal",
        "gruplac",
        "publicacion_en_cvlac",
        "publindex_categoria",
        "coincidencia_confianza",
        "notas"
      ],
      "properties": {
        "perfil_encontrado": { "type": "boolean" },
        "url": { "type": ["string", "null"], "format": "uri" },
        "cod_rh": { "type": ["string", "null"] },
        "categoria": {
          "type": ["string", "null"],
          "enum": [
            "Investigador Senior",
            "Investigador Asociado",
            "Investigador Junior",
            null
          ]
        },
        "afiliacion_principal": { "type": ["string", "null"] },
        "gruplac": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["nombre", "url", "categoria_grupo"],
            "properties": {
              "nombre": { "type": "string" },
              "url": { "type": ["string", "null"], "format": "uri" },
              "categoria_grupo": { "type": ["string", "null"] }
            }
          }
        },
        "publicacion_en_cvlac": { "type": ["boolean", "null"] },
        "publindex_categoria": {
          "type": ["string", "null"],
          "enum": ["A1", "A2", "B", "C", null]
        },
        "coincidencia_confianza": {
          "type": "string",
          "enum": ["alta", "media", "baja"]
        },
        "notas": { "type": "string" }
      }
    },
    "autor": {
      "type": "object",
      "required": [
        "nombre",
        "orcid",
        "afiliacion",
        "pais_afiliacion",
        "rol",
        "h_index",
        "h_index_fuente",
        "creditos",
        "cvlac"
      ],
      "properties": {
        "nombre": { "type": "string" },
        "orcid": { "type": ["string", "null"] },
        "afiliacion": { "type": ["string", "null"] },
        "pais_afiliacion": {
          "type": ["string", "null"],
          "description": "Código ISO 3166-1 alpha-2, ej. CO"
        },
        "rol": {
          "type": "string",
          "enum": [
            "autor",
            "correspondencia",
            "primer_autor",
            "ultimo_autor",
            "coautor"
          ]
        },
        "h_index": { "type": ["integer", "null"], "minimum": 0 },
        "h_index_fuente": {
          "type": "string",
          "enum": ["openalex", "semanticscholar", "no_disponible"]
        },
        "creditos": { "type": ["string", "null"] },
        "cvlac": {
          "oneOf": [
            { "$ref": "#/definitions/cvlac" },
            { "type": "null" }
          ],
          "description": "null para autores no colombianos cuando enriquecer_cvlac es solo_colombianos"
        }
      }
    },
    "hallazgo": {
      "type": "object",
      "required": [
        "ranking",
        "tema",
        "noticia",
        "evidencia_cientifica",
        "relevancia_doctoral",
        "nivel_confianza",
        "riesgos_sesgo"
      ],
      "properties": {
        "ranking": { "type": "integer", "minimum": 1 },
        "tema": { "type": "string" },
        "noticia": {
          "type": "object",
          "required": ["titulo", "fuente", "url", "fecha", "tipo"],
          "properties": {
            "titulo": { "type": "string" },
            "fuente": { "type": "string" },
            "url": { "type": ["string", "null"], "format": "uri" },
            "fecha": { "type": ["string", "null"] },
            "tipo": {
              "type": "string",
              "enum": ["noticia", "comunicado", "blog_institucional", "otro"]
            }
          }
        },
        "evidencia_cientifica": {
          "type": ["object", "null"],
          "required": [
            "titulo",
            "doi",
            "url",
            "tipo_publicacion",
            "estado_publicacion",
            "fecha_publicacion",
            "fecha_precision",
            "revista_o_venue",
            "metricas_venue",
            "abstract_original",
            "abstract_simplificado",
            "puntos_importantes",
            "impactos",
            "autores",
            "creditos_contribucion",
            "open_access"
          ],
          "properties": {
            "titulo": { "type": ["string", "null"] },
            "doi": { "type": ["string", "null"] },
            "url": { "type": ["string", "null"], "format": "uri" },
            "tipo_publicacion": {
              "type": "string",
              "enum": [
                "journal-article",
                "preprint",
                "posted-content",
                "proceedings-article",
                "review-article",
                "systematic-review",
                "meta-analysis",
                "book-chapter",
                "report",
                "other"
              ]
            },
            "tipo_publicacion_etiqueta": { "type": "string" },
            "estado_publicacion": {
              "type": "string",
              "enum": [
                "publicado",
                "preprint",
                "en_revision",
                "aceptado",
                "retractado",
                "desconocido"
              ]
            },
            "fecha_publicacion": { "type": ["string", "null"] },
            "fecha_precision": {
              "type": "string",
              "enum": ["dia", "mes", "anio", "desconocido"]
            },
            "revista_o_venue": {
              "type": "object",
              "required": [
                "nombre",
                "issn",
                "editorial",
                "pais",
                "indexacion",
                "publindex"
              ],
              "properties": {
                "nombre": { "type": ["string", "null"] },
                "issn": { "type": ["string", "null"] },
                "editorial": { "type": ["string", "null"] },
                "pais": { "type": ["string", "null"] },
                "indexacion": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "publindex": {
                  "type": "object",
                  "required": ["categoria", "fuente", "notas"],
                  "properties": {
                    "categoria": {
                      "type": ["string", "null"],
                      "enum": ["A1", "A2", "B", "C", "no_indexada", null]
                    },
                    "fuente": { "type": "string" },
                    "notas": { "type": "string" }
                  }
                }
              }
            },
            "metricas_venue": {
              "type": "object",
              "required": [
                "cuartil",
                "percentil",
                "fuente_metrica",
                "sjr",
                "impact_factor",
                "notas"
              ],
              "properties": {
                "cuartil": {
                  "type": "string",
                  "enum": ["Q1", "Q2", "Q3", "Q4", "no_confirmado"]
                },
                "percentil": { "type": ["number", "null"] },
                "fuente_metrica": {
                  "type": "string",
                  "enum": [
                    "scimago",
                    "jcr",
                    "doaj",
                    "openalex",
                    "publindex",
                    "no_disponible"
                  ]
                },
                "sjr": { "type": ["number", "null"] },
                "impact_factor": { "type": ["number", "null"] },
                "notas": { "type": "string" }
              }
            },
            "abstract_original": { "type": ["string", "null"] },
            "abstract_simplificado": { "type": ["string", "null"] },
            "puntos_importantes": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "maxItems": 7
            },
            "impactos": {
              "type": "object",
              "required": ["cientifico", "tecnico", "social", "doctoral"],
              "properties": {
                "cientifico": { "type": "string" },
                "tecnico": { "type": "string" },
                "social": { "type": "string" },
                "doctoral": { "type": "string" }
              }
            },
            "autores": {
              "type": "array",
              "items": { "$ref": "#/definitions/autor" }
            },
            "creditos_contribucion": { "type": ["string", "null"] },
            "open_access": { "type": ["boolean", "null"] },
            "notas": { "type": "string" }
          }
        },
        "relevancia_doctoral": { "type": "string" },
        "nivel_confianza": {
          "type": "string",
          "enum": ["alta", "media", "baja"]
        },
        "riesgos_sesgo": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
